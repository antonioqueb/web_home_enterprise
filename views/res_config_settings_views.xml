<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_home" model="ir.ui.view">
        <field name="name">res.config.settings.view.home</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="before">
                <div class="app_settings_block" data-string="Home Screen" string="Home Screen" data-key="home_screen">
                    <h2>Home Screen Theme</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Background Type</span>
                                <div class="content-group">
                                    <div class="mt8">
                                        <field name="home_background_type" widget="radio"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box"
                             attrs="{'invisible': [('home_background_type', '!=', 'solid')]}">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Background Color</span>
                                <div class="content-group">
                                    <div class="mt8">
                                        <field name="home_background_color" widget="color"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box"
                             attrs="{'invisible': [('home_background_type', '!=', 'image')]}">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Background Image</span>
                                <div class="content-group">
                                    <div class="mt8">
                                        <field name="home_background_image" widget="image"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
